extends index.pug 

block content 
    h1='Vista de Productos'
    if hasProducts
        table(class="table table-hover")
            thead
                tr
                    th='Nombre'
                    th='Precio'
                    th='foto'
            thead
            tbody
                each product in listProducts
                    tr 
                        td=product.title
                        td=product.price
                        td
                            img(src=product.thumbnail alt=product.title width="24" height="24")                
    else
        div(class="alert alert-warning" role="alert")='No hay productos'
